# Copy this file to .env.local and fill values locally.
# Do not commit real tokens.

# Tushare Pro API
TUSHARE_TOKEN=
# Optional bridge override. Leave blank to use the library default.
TUSHARE_HTTP_URL=
# Set to 1 when the bridge endpoint should ignore shell proxy variables.
TUSHARE_DISABLE_PROXY=1
# Request pacing for skill-owned Tushare router calls.
TUSHARE_REQUEST_INTERVAL_SECONDS=0.7
TUSHARE_REQUEST_JITTER_SECONDS=0.2

# Optional runtime overrides
# Uncomment only after creating the local TOML file.
# INVESTMENT_SYSTEM_CONFIG=investment_system/config/data_sources.local.toml
# INVESTMENT_SYSTEM_TIMEZONE=Asia/Shanghai
